INTERFILE	:=
version of keys	:= 3.3
number format		:= float
number of bytes per pixel	:= 4
imagedata byte order	:= littleendian
orientation		:= 3
number of dimensions	:= 3
matrix size [1]	:= 4
matrix size [2]	:= 5
matrix size [3]	:= 6
matrix size [4]	:= 1
scaling factor (mm/pixel) [1]	:= 2.0
scaling factor (mm/pixel) [2]	:= 3.0
scaling factor (mm/pixel) [3]	:= 4.0
mmppix	:=   -2.0 -3.0 -4.0
center	:=   10.0 -20.0 30.0
